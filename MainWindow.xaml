<Window x:Class="ArcelikExcelApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:ArcelikExcelApp.Converters"
        Title="Arçelik - Gelişmiş Yönetim Paneli" Height="800" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        FontFamily="Segoe UI"
        Icon="/Assets/AppIcon.png"
        Background="#F4F6FA"
        TextElement.Foreground="#333333">

    <Window.Resources>
        <converters:BooleanToReadBackgroundConverter x:Key="BooleanToReadBackgroundConverter"/>
        <converters:NotificationTypeToColorConverter x:Key="NotificationTypeToColorConverter"/>
        <converters:NotificationTypeToIconConverter x:Key="NotificationTypeToIconConverter"/>
        
        <!-- Modern Sidebar Button Style -->
        <Style x:Key="PremiumNavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A5B1"/>
            <Setter Property="Height" Value="55"/>
            <Setter Property="Margin" Value="15,5,15,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="12" Padding="20,0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2A2D3E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#E02020"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1C1E2B" CornerRadius="0">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.1" Direction="0"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header / Logo -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="30,40,20,40">
                    <Border Width="45" Height="45" Background="#E02020" CornerRadius="12">
                        <Viewbox Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="{StaticResource ArcelikLogoGeometry}" Fill="White"/>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="Arçelik" FontSize="32" FontFamily="{StaticResource ArcelikFont}" FontWeight="Bold" Foreground="White" Margin="15,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel x:Name="MenuStackPanel" Grid.Row="1" Margin="0,10,0,0">
                    <TextBlock Text="ANA MENÜ" Foreground="#666A7D" FontSize="12" FontWeight="SemiBold" Margin="35,0,0,15"/>
                    
                    <Button x:Name="BtnDashboard" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="Anasayfa">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboard" Width="22" Height="22" Margin="0,0,15,0"/>
                            <TextBlock Text="Dashboard" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="Kea">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CoffeeMaker" Width="22" Height="22" Margin="0,0,15,0"/>
                            <TextBlock Text="Küçük Ev Aletleri" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="BeyazEsya">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="WashingMachine" Width="22" Height="22" Margin="0,0,15,0"/>
                            <TextBlock Text="Beyaz Eşya" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnExcelViewer" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="ExcelViewer">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="MicrosoftExcel" Width="22" Height="22" Margin="0,0,15,0"/>
                            <TextBlock Text="Excel Görüntüleyici" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <StackPanel x:Name="AdminSection">
                        <TextBlock Text="İŞLEMLER" Foreground="#666A7D" FontSize="12" FontWeight="SemiBold" Margin="35,25,0,15"/>

                        <Button x:Name="BtnCalculator" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="YeniFiyat">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CalculatorVariant" Width="22" Height="22" Margin="0,0,15,0"/>
                                <TextBlock Text="Maliyet Hesaplama" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnImportExcel" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="Excell">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="DatabaseImport" Width="22" Height="22" Margin="0,0,15,0"/>
                                <TextBlock Text="Excel İçeri Aktar" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnUserManagement" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="UserManagement">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountGroup" Width="22" Height="22" Margin="0,0,15,0"/>
                                <TextBlock Text="Kullanıcı Yönetimi" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <TextBlock Text="KULLANICI" Foreground="#666A7D" FontSize="12" FontWeight="SemiBold" Margin="35,25,0,15"/>
                    <Button x:Name="BtnSettingsSidebar" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="Settings">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CogOutline" Width="22" Height="22" Margin="0,0,15,0"/>
                            <TextBlock Text="Ayarlar" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <!-- Footer Profile -->
                <Border Grid.Row="2" Margin="20" Background="#232635" CornerRadius="12" Padding="15">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="#3A3F55">
                                <materialDesign:PackIcon Kind="AccountTie" Width="24" Height="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtUsername" Text="Yönetici" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtRole" Text="Admin" Foreground="#4CAF50" FontSize="12"/>
                            </StackPanel>
                            <Button Grid.Column="2" Style="{StaticResource MaterialDesignFloatingActionMiniLightButton}" 
                                    Width="30" Height="30" Background="Transparent" BorderBrush="Transparent"
                                    Click="BtnLogout_Click">
                                <materialDesign:PackIcon Kind="Logout" Foreground="#EF5350" Width="18" Height="18"/>
                            </Button>
                        </Grid>
                        <!-- Uygulama Versiyonu -->
                        <TextBlock x:Name="TxtAppVersion" Text="v1.0.8" Foreground="#666A7D" FontSize="11" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Topbar -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="TxtPageTitle" Text="Dashboard" FontSize="32" FontWeight="Bold" Foreground="#1A1A24" VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Modern Notification Bell with Badge -->
                    <materialDesign:Badged x:Name="BadgeNotifications" Badge="0" BadgeBackground="Red" BadgeForeground="White" Margin="0,0,15,0">
                        <Button Style="{StaticResource MaterialDesignFloatingActionMiniLightButton}" 
                                Background="White" BorderBrush="Transparent" Click="BtnNotifications_Click">
                            <materialDesign:PackIcon Kind="BellOutline" Foreground="#666A7D" Width="20" Height="20"/>
                        </Button>
                    </materialDesign:Badged>
                    
                    <!-- Notification Popup Panel -->
                    <Popup x:Name="PopupNotifications" AllowsTransparency="True" StaysOpen="False" 
                           Placement="Bottom" PlacementTarget="{Binding ElementName=BadgeNotifications}"
                           PopupAnimation="Slide" VerticalOffset="10">
                        <materialDesign:Card Width="380" MaxHeight="500" UniformCornerRadius="18" Background="White" 
                                           materialDesign:ElevationAssist.Elevation="Dp12" Margin="0,0,15,15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <Border Grid.Row="0" Padding="20,15" Background="#F8F9FB" CornerRadius="18,18,0,0">
                                    <Grid>
                                        <TextBlock Text="Bildirimler" FontSize="18" FontWeight="Bold" Foreground="#1A1A24" VerticalAlignment="Center"/>
                                        <Button HorizontalAlignment="Right" Content="Tümünü Okundu Say" 
                                                Style="{StaticResource MaterialDesignFlatButton}" Foreground="#3949AB" 
                                                FontSize="12" Click="BtnMarkAllRead_Click"/>
                                    </Grid>
                                </Border>
                                
                                <ScrollViewer Grid.Row="1" MaxHeight="350" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="ItemsNotifications">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource MaterialDesignFlatButton}" Padding="0" Height="Auto" 
                                                        HorizontalContentAlignment="Stretch" Click="BtnNotificationDetail_Click" Tag="{Binding Id}">
                                                    <Border Padding="20,15" BorderBrush="#F1F3F9" BorderThickness="0,0,0,1" 
                                                            Background="{Binding IsRead, Converter={StaticResource BooleanToReadBackgroundConverter}}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                 <ColumnDefinition Width="Auto"/>
                                                                 <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            
                                                            <Border Width="40" Height="40" CornerRadius="12" 
                                                                    Background="{Binding Type, Converter={StaticResource NotificationTypeToColorConverter}, ConverterParameter=Light}">
                                                                <materialDesign:PackIcon Kind="{Binding Type, Converter={StaticResource NotificationTypeToIconConverter}}" 
                                                                                       Foreground="{Binding Type, Converter={StaticResource NotificationTypeToColorConverter}}"
                                                                                       Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            
                                                            <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Foreground="#1A1A24"/>
                                                                <TextBlock Text="{Binding Message}" FontSize="13" Foreground="#7E84A3" TextWrapping="Wrap" MaxHeight="40" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                                <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:dd MMM HH:mm}}" FontSize="11" Foreground="#BDBDBD" Margin="0,5,0,0"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                
                                <Border Grid.Row="2" Padding="15" Background="White" CornerRadius="0,0,18,18" BorderBrush="#F1F3F9" BorderThickness="0,1,0,0">
                                    <Button Content="Tüm Bildirimleri Gör" Style="{StaticResource MaterialDesignFlatButton}" 
                                            HorizontalAlignment="Center" Foreground="#E02020" FontWeight="Bold" Click="BtnViewAllNotifications_Click"/>
                                </Border>
                            </Grid>
                        </materialDesign:Card>
                    </Popup>
                </StackPanel>
            </Grid>

            <!-- Dynamic Content Control with Shadow -->
            <Border Grid.Row="1" Background="White" CornerRadius="20">
                <Border.Effect>
                    <DropShadowEffect Color="#888888" BlurRadius="25" Opacity="0.08" Direction="270" ShadowDepth="5"/>
                </Border.Effect>
                
                <ContentControl x:Name="MainContentControl" Margin="20"/>
            </Border>

            <!-- Modern Global Snackbar -->
            <materialDesign:Snackbar x:Name="MainSnackbar" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,20,20,0" MessageQueue="{materialDesign:MessageQueue}">
                <materialDesign:Snackbar.Resources>
                    <Style TargetType="materialDesign:SnackbarMessage">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="materialDesign:SnackbarMessage">
                                    <materialDesign:Card UniformCornerRadius="12" Background="White" Padding="20,12" materialDesign:ElevationAssist.Elevation="Dp3" BorderBrush="#4CAF50" BorderThickness="0,0,0,3">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="CheckCircleOutline" Foreground="#4CAF50" Width="24" Height="24" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}" 
                                                       Foreground="#1A1A24" FontWeight="SemiBold" FontSize="14" 
                                                       Margin="15,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </materialDesign:Card>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </materialDesign:Snackbar.Resources>
            </materialDesign:Snackbar>
        </Grid>
        <!-- Global Modern Dialog Overlay -->
        <Grid x:Name="ModernDialogOverlay" Grid.ColumnSpan="2" Visibility="Collapsed">
            <Border Background="#111A1A24">
                <Border.Effect>
                    <BlurEffect Radius="15"/>
                </Border.Effect>
            </Border>
            <Grid Background="#22FFFFFF">
                <materialDesign:Card Width="450" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                    UniformCornerRadius="25" Background="White">
                    <materialDesign:Card.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="40" Opacity="0.2" Direction="270" ShadowDepth="10"/>
                    </materialDesign:Card.Effect>
                    <Border Padding="35">
                        <StackPanel>
                            <Border x:Name="BorderDialogIcon" Width="60" Height="60" Background="#E3F2FD" CornerRadius="30" Margin="0,0,0,20">
                                <materialDesign:PackIcon x:Name="IconDialog" Kind="Information" Width="30" Height="30" Foreground="#2196F3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            
                            <TextBlock x:Name="TxtDialogTitle" Text="Başlık" FontSize="22" FontWeight="Bold" 
                                       Foreground="#1A1A24" Margin="0,0,0,10" HorizontalAlignment="Center" TextAlignment="Center"/>
                            
                            <ScrollViewer MaxHeight="250" VerticalScrollBarVisibility="Auto" Margin="0,0,0,30">
                                <TextBlock x:Name="TxtDialogMessage" Text="Mesaj içeriği..." FontSize="15" 
                                           Foreground="#666A7D" TextWrapping="Wrap" LineHeight="22" TextAlignment="Center"/>
                            </ScrollViewer>
                            
                            <Grid x:Name="GridDialogButtons">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Button x:Name="BtnDialogCancel" Grid.Column="0" Content="İptal" Style="{StaticResource MaterialDesignFlatButton}" 
                                        Foreground="#7E84A3" Height="48" Margin="0,0,5,0" Click="BtnDialogResult_Click" Tag="False"/>
                                
                                <Button x:Name="BtnDialogConfirm" Grid.Column="1" Content="Tamam" Foreground="White" Background="#1A1A24" BorderBrush="#1A1A24" 
                                        materialDesign:ButtonAssist.CornerRadius="14" Height="48" FontWeight="SemiBold"
                                        Click="BtnDialogResult_Click" Tag="True"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </Grid>
</Window>
