<UserControl x:Class="ArcelikExcelApp.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="White">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Grid Grid.Row="0" Margin="0,0,0,30">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="50" Height="50" Background="#F1F3F9" CornerRadius="15">
                    <materialDesign:PackIcon Kind="CogOutline" Width="28" Height="28" Foreground="#666A7D" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="20,0,0,0">
                    <TextBlock Text="Ayarlar ve Profil" FontSize="28" FontWeight="Bold" Foreground="#1A1A24"/>
                    <TextBlock Text="Hesap güvenliğinizi ve uygulama tercihlerinizi yönetin" FontSize="14" Foreground="#7E84A3" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,20,0">
                <!-- Profile Overview - Full Width -->
                <materialDesign:Card UniformCornerRadius="20" Background="White" Padding="35" Margin="0,0,0,25">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="90" Height="90" Background="#FFEAEA" CornerRadius="45">
                            <materialDesign:PackIcon Kind="AccountTie" Width="45" Height="45" Foreground="#E02020" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="30,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtProfileName" Text="Yönetici" FontSize="26" FontWeight="Bold" Foreground="#1A1A24"/>
                            <TextBlock x:Name="TxtProfileRole" Text="Admin Yetkisi" FontSize="15" Foreground="#4CAF50" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            <TextBlock Text="Sistem Kayıt Tarihi: 27.04.2026" FontSize="13" Foreground="#7E84A3" Margin="0,8,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="2" VerticalAlignment="Top" Background="#E8F5E9" Padding="12,6" CornerRadius="10">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#4CAF50" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Oturum Aktif" Foreground="#2E7D32" FontWeight="Bold" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </materialDesign:Card>

                <!-- Security and Forms - Two Columns -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left: Password Form -->
                    <materialDesign:Card Grid.Column="0" UniformCornerRadius="20" Background="White" Padding="35" Margin="0,0,15,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                                <materialDesign:PackIcon Kind="ShieldLockOutline" Width="26" Height="26" Foreground="#3949AB" VerticalAlignment="Center"/>
                                <TextBlock Text="Güvenlik Ayarları" FontSize="20" FontWeight="Bold" Foreground="#1A1A24" VerticalAlignment="Center" Margin="15,0,0,0"/>
                            </StackPanel>

                            <TextBlock Text="Mevcut Şifre" FontSize="14" FontWeight="SemiBold" Foreground="#1A1A24" Margin="0,0,0,10"/>
                            <PasswordBox x:Name="TxtCurrentPassword" Style="{StaticResource MaterialDesignOutlinedPasswordBox}" materialDesign:HintAssist.Hint="Doğrulama için mevcut şifreniz" Margin="0,0,0,20" Height="55"/>

                            <TextBlock Text="Yeni Şifre" FontSize="14" FontWeight="SemiBold" Foreground="#1A1A24" Margin="0,0,0,10"/>
                            <PasswordBox x:Name="TxtNewPassword" Style="{StaticResource MaterialDesignOutlinedPasswordBox}" materialDesign:HintAssist.Hint="En az 6 karakter" Margin="0,0,0,20" Height="55"/>

                            <TextBlock Text="Yeni Şifre (Tekrar)" FontSize="14" FontWeight="SemiBold" Foreground="#1A1A24" Margin="0,0,0,10"/>
                            <PasswordBox x:Name="TxtConfirmPassword" Style="{StaticResource MaterialDesignOutlinedPasswordBox}" materialDesign:HintAssist.Hint="Yeni şifreyi tekrar girin" Margin="0,0,0,10" Height="55"/>

                            <TextBlock x:Name="TxtSettingsError" Foreground="#D32F2F" FontSize="13" Margin="0,5,0,20" HorizontalAlignment="Left" Visibility="Collapsed" TextWrapping="Wrap"/>

                            <Button Content="Şifreyi Güvenli Şekilde Güncelle" Foreground="White" Background="#E02020" BorderBrush="#E02020" Height="55" FontSize="16" FontWeight="Bold" materialDesign:ButtonAssist.CornerRadius="14" Click="BtnUpdatePassword_Click"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Right: Info Panels -->
                    <StackPanel Grid.Column="1" Margin="15,0,0,0">
                        <materialDesign:Card UniformCornerRadius="20" Background="#F8F9FB" Padding="30" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Şifre Güvenliği" FontWeight="Bold" FontSize="16" Foreground="#1A1A24" Margin="0,0,0,15"/>
                                <TextBlock Text="Güçlü bir şifre hesabınızı korumanın en iyi yoludur." FontSize="13" Foreground="#7E84A3" TextWrapping="Wrap" Margin="0,0,0,20"/>
                                
                                <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CheckCircle" Foreground="#4CAF50" Width="18" Height="18"/>
                                    <TextBlock Text="En az 8 karakter uzunluğunda" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="13" Foreground="#666A7D"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CheckCircle" Foreground="#4CAF50" Width="18" Height="18"/>
                                    <TextBlock Text="Büyük/küçük harf kullanımı" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="13" Foreground="#666A7D"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CheckCircle" Foreground="#4CAF50" Width="18" Height="18"/>
                                    <TextBlock Text="Rakam veya sembol kullanımı" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="13" Foreground="#666A7D"/>
                                </StackPanel>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card UniformCornerRadius="20" Background="#E8EAF6" Padding="30" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Hesap Durumu" FontWeight="Bold" FontSize="16" Foreground="#1A1A24" Margin="0,0,0,10"/>
                                <TextBlock Text="Hesabınız şu anda en yüksek yetki seviyesinde ve tam koruma altındadır." FontSize="13" Foreground="#3949AB" TextWrapping="Wrap"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card UniformCornerRadius="20" Background="#F1F3F9" Padding="30">
                            <StackPanel>
                                <TextBlock Text="Cihaz Bilgisi" FontWeight="Bold" FontSize="16" Foreground="#1A1A24" Margin="0,0,0,10"/>
                                <TextBlock Text="Bu hesap şu cihaza kilitlenmiştir:" FontSize="13" Foreground="#7E84A3" Margin="0,0,0,5"/>
                                <TextBlock x:Name="TxtDeviceId" Text="Cihaz Kimliği: Bekleniyor..." FontSize="12" Foreground="#1A1A24" FontWeight="SemiBold" FontFamily="Consolas"/>
                            </StackPanel>
                        </materialDesign:Card>
                    </StackPanel>
                </Grid>

                <!-- Agreement Management (Admin Only) -->
                <materialDesign:Card x:Name="CardAgreementManagement" UniformCornerRadius="20" Background="White" Padding="35" Margin="0,0,0,25" Visibility="Collapsed">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                            <materialDesign:PackIcon Kind="FileDocumentEditOutline" Width="26" Height="26" Foreground="#E02020" VerticalAlignment="Center"/>
                            <TextBlock Text="Kullanıcı Sözleşmesi Yönetimi" FontSize="20" FontWeight="Bold" Foreground="#1A1A24" VerticalAlignment="Center" Margin="15,0,0,0"/>
                        </StackPanel>

                        <TextBlock Text="Yeni bir sözleşme yayınladığınızda, tüm kullanıcıların (mevcut kullanıcılar dahil) bir sonraki girişlerinde bu sözleşmeyi onaylaması zorunlu olacaktır." 
                                 FontSize="14" Foreground="#7E84A3" Margin="0,0,0,20" TextWrapping="Wrap"/>

                        <TextBox x:Name="TxtAgreementVersion" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Sözleşme Versiyonu (Örn: v1.1)"
                                 Margin="0,0,0,15" Height="50" VerticalContentAlignment="Center"/>

                        <TextBox x:Name="TxtAgreementContent" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Sözleşme İçeriği"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="200" Margin="0,0,0,20" Padding="10"/>

                        <Button x:Name="BtnSaveAgreement" Content="Yeni Sözleşmeyi Yayınla" 
                                Height="50" Background="#E02020" Foreground="White" 
                                FontWeight="Bold" materialDesign:ButtonAssist.CornerRadius="10"
                                Click="BtnSaveAgreement_Click"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Data Management Section -->


                <materialDesign:Card x:Name="CardDataManagement" UniformCornerRadius="20" Background="White" Padding="35" Margin="0,25,0,25">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                            <materialDesign:PackIcon Kind="DatabaseRefresh" Width="26" Height="26" Foreground="#E02020" VerticalAlignment="Center"/>
                            <TextBlock Text="Veri Yönetimi ve Sıfırlama" FontSize="20" FontWeight="Bold" Foreground="#1A1A24" VerticalAlignment="Center" Margin="15,0,0,0"/>
                        </StackPanel>
                        
                        <TextBlock Text="Seçili tabloları kalıcı olarak sıfırlayabilirsiniz (TRUNCATE). Bu işlem tüm verileri siler ve ID'leri 1'den başlatır. Bu işlem geri alınamaz." 
                                 FontSize="14" Foreground="#7E84A3" Margin="0,0,0,20" TextWrapping="Wrap"/>

                        <CheckBox x:Name="ChkSelectAll" Content="Tümünü Seç" FontWeight="Bold" Margin="0,0,0,10" 
                                  Checked="ChkSelectAll_Checked" Unchecked="ChkSelectAll_Unchecked"/>
                        
                        <Separator Margin="0,0,0,15" Background="#F1F3F9"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <CheckBox x:Name="ChkCostCalculations" Content="Maliyet Hesaplamaları" Margin="0,5"/>
                                <CheckBox x:Name="ChkOlizCampaigns" Content="Oliz Kampanyaları" Margin="0,5"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <CheckBox x:Name="ChkKeaProducts" Content="KEA Ürünleri" Margin="0,5"/>
                                <CheckBox x:Name="ChkWhiteGoodsProducts" Content="Beyaz Eşya Ürünleri" Margin="0,5"/>
                            </StackPanel>
                        </Grid>

                        <Button x:Name="BtnResetTables" Content="Seçili Tabloları Sıfırla" 
                                Margin="0,30,0,0" Height="50" Background="#1A1A24" Foreground="White" 
                                FontWeight="Bold" materialDesign:ButtonAssist.CornerRadius="10"
                                Click="BtnResetTables_Click">
                        </Button>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>

        <!-- Modern Premium Toast Notification (Restored) -->
        <materialDesign:Card x:Name="ToastCard" Visibility="Collapsed" Opacity="0"
                            VerticalAlignment="Top" HorizontalAlignment="Right" 
                            Margin="0,30,30,0" UniformCornerRadius="15" 
                            Background="White" Width="350"
                            materialDesign:ElevationAssist.Elevation="Dp8">
            <materialDesign:Card.RenderTransform>
                <TranslateTransform X="50"/>
            </materialDesign:Card.RenderTransform>
            <Border BorderBrush="#4CAF50" BorderThickness="5,0,0,0" Padding="25,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Width="36" Height="36" Background="#E8F5E9" CornerRadius="18">
                        <materialDesign:PackIcon Kind="CheckCircle" Foreground="#4CAF50" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel Grid.Column="1" Margin="15,0">
                        <TextBlock Text="Başarılı!" FontWeight="Bold" FontSize="14" Foreground="#1A1A24"/>
                        <TextBlock x:Name="TxtToastMessage" Text="İşlem başarıyla tamamlandı." 
                                 Foreground="#7E84A3" FontSize="13" Margin="0,2,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconButton}" Width="24" Height="24" 
                            Click="BtnCloseToast_Click" Foreground="#BDBDBD">
                        <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                    </Button>
                </Grid>
            </Border>
        </materialDesign:Card>
        <!-- Custom Modern Alert Overlay (Glassmorphism) -->
        <Grid x:Name="AlertOverlay" Visibility="Collapsed" Grid.RowSpan="2" Margin="-30">
            <Border Background="#111A1A24">
                <Border.Effect>
                    <BlurEffect Radius="20"/>
                </Border.Effect>
            </Border>
            <Grid Background="#22FFFFFF">
                <materialDesign:Card Width="450" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                    UniformCornerRadius="25" Background="White">
                    <materialDesign:Card.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="40" Opacity="0.2" Direction="270" ShadowDepth="10"/>
                    </materialDesign:Card.Effect>
                    <Border Padding="35">
                        <StackPanel>
                            <Border x:Name="BorderAlertIcon" Width="60" Height="60" Background="#FFF3E0" CornerRadius="30" Margin="0,0,0,20">
                                <materialDesign:PackIcon x:Name="IconAlert" Kind="AlertCircleOutline" Width="30" Height="30" Foreground="#FF9800" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            
                            <TextBlock x:Name="TxtAlertTitle" Text="Tablo Sıfırlama Onayı" FontSize="22" FontWeight="Bold" 
                                       Foreground="#1A1A24" Margin="0,0,0,10" HorizontalAlignment="Center" TextAlignment="Center"/>
                            
                            <TextBlock x:Name="TxtAlertMessage" Text="Seçili tablolar tamamen sıfırlanacaktır. Bu işlem geri alınamaz. Devam etmek istiyor musunuz?" FontSize="15" 
                                       Foreground="#666A7D" TextWrapping="Wrap" LineHeight="22" TextAlignment="Center" Margin="0,0,0,30"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="BtnCancelAlert" Content="Vazgeç" Grid.Column="0" Margin="0,0,10,0"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        materialDesign:ButtonAssist.CornerRadius="14" Height="48"
                                        Click="BtnCancelAlert_Click"/>
                                <Button x:Name="BtnConfirmAction" Content="Evet, Sıfırla" Grid.Column="1" Margin="10,0,0,0"
                                        Foreground="White" Background="#E02020" BorderBrush="#E02020" 
                                        materialDesign:ButtonAssist.CornerRadius="14" Height="48" FontWeight="Bold"
                                        Click="BtnConfirmAlert_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
