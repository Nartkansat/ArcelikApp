<UserControl x:Class="ArcelikExcelApp.Views.BeyazEsyaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F4F6F8"
             Loaded="UserControl_Loaded"
             Focusable="True"
             PreviewKeyDown="UserControl_PreviewKeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Başlık -->
        <Border Grid.Row="0" Background="#1C2B4A" CornerRadius="10" Padding="24,16">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="WashingMachine" Width="30" Height="30" Foreground="#3B82F6" VerticalAlignment="Center"/>
                <StackPanel Margin="12,0,0,0">
                    <TextBlock Text="Beyaz Eşya Maliyetleri" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Sisteme kaydedilmiş Beyaz Eşya maliyet hesaplamaları" FontSize="12" Foreground="#A0AEC0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Arama Çubuğu -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Search Box -->
                <TextBox x:Name="TxtSearch" Grid.Column="0"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Ürün Kodu veya Adı Ara (Ctrl+F)"
                         materialDesign:TextFieldAssist.UnderlineBrush="#E02020"
                         CaretBrush="#E02020"
                         TextChanged="TxtSearch_TextChanged">
                </TextBox>
                <materialDesign:PackIcon Kind="Magnify" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#94A3B8"/>
                
                <TextBlock Grid.Column="1" x:Name="TxtTotalCount" Text="Toplam: 0 Ürün" 
                           VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#64748B" FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <materialDesign:Card Grid.Row="2" Margin="16,16,16,8" UniformCornerRadius="10">
            <DataGrid x:Name="GridBeyazEsya" 
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Background="White"
                      BorderThickness="0"
                      HeadersVisibility="Column"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFAFA"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F1F5F9"
                      materialDesign:DataGridAssist.CellPadding="12,8,12,8">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Excel'de Aç" Click="MenuItem_OpenExcel_Click">
                            <MenuItem.Icon>
                                <materialDesign:PackIcon Kind="MicrosoftExcel" Foreground="#10B981"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Tüm Valörleri Gör" Click="MenuItem_ViewAllValors_Click">
                            <MenuItem.Icon>
                                <materialDesign:PackIcon Kind="ViewList" Foreground="#3949AB"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Arçelik.com.tr'de Aç" Click="MenuItem_OpenInArcelik_Click">
                            <MenuItem.Icon>
                                <materialDesign:PackIcon Kind="Web" Foreground="#E02020"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Ürün Kodu" Binding="{Binding ProductCode}" Width="130"/>
                    <DataGridTextColumn Header="Ürün Adı" Binding="{Binding ProductName}" Width="*"/>
                    <DataGridTextColumn Header="Baz Fiyat" Binding="{Binding PricePP, StringFormat={}{0:N2} ₺}" Width="110"/>
                    <DataGridTextColumn Header="İndirim" Binding="{Binding PriceConversion, StringFormat={}{0:N2} ₺}" Width="100"/>
                    <DataGridTextColumn Header="Net Maliyet" Binding="{Binding PurchasePrice, StringFormat={}{0:N2} ₺}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#16A34A"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn x:Name="ColCardPrice"  Binding="{Binding CardPurchasePrice, StringFormat={}{0:N2} ₺}" Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#DC2626"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Tarih" Binding="{Binding CreatedDate, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>

        <!-- Sayfalama (Pagination) -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="BtnPrev" Content="Önceki" Style="{StaticResource MaterialDesignOutlinedButton}" 
                        Foreground="#E02020" BorderBrush="#E02020"
                        Height="32" Padding="12,0" Margin="0,0,16,0" Click="BtnPrev_Click"/>
                
                <TextBlock x:Name="TxtPageInfo" Text="Sayfa 1 / 1" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569"/>
                
                <Button x:Name="BtnNext" Content="Sonraki" Style="{StaticResource MaterialDesignOutlinedButton}" 
                        Foreground="#E02020" BorderBrush="#E02020"
                        Height="32" Padding="12,0" Margin="16,0,0,0" Click="BtnNext_Click"/>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Grid x:Name="OverlayLoading" Grid.RowSpan="4" Background="#AAFFFFFF" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" IsIndeterminate="True" Width="40" Height="40" Foreground="#E02020" HorizontalAlignment="Center"/>
                <TextBlock Text="Veriler Yükleniyor..." Margin="0,12,0,0" FontWeight="SemiBold" Foreground="#1C2B4A"/>
            </StackPanel>
        </Grid>

        <!-- Valör Dialog Overlay -->
        <Grid x:Name="ValorDialogOverlay" Grid.RowSpan="4" Visibility="Collapsed">
            <Border Background="#221A1A24">
                <Border.Effect>
                    <BlurEffect Radius="10"/>
                </Border.Effect>
            </Border>
            <materialDesign:Card Width="500" VerticalAlignment="Center" HorizontalAlignment="Center" UniformCornerRadius="16" Background="White">
                <materialDesign:Card.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="30" Opacity="0.15" Direction="270" ShadowDepth="5"/>
                </materialDesign:Card.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#F8F9FB" Padding="20,16" CornerRadius="16,16,0,0" BorderThickness="0,0,0,1" BorderBrush="#E2E8F0">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="40" Height="40" Background="#E8EAF6" CornerRadius="20">
                                <materialDesign:PackIcon Kind="CashMultiple" Width="24" Height="24" Foreground="#3949AB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Tüm Valör Maliyetleri" FontSize="18" FontWeight="Bold" Foreground="#1A1A24"/>
                                <TextBlock x:Name="TxtValorProductName" Text="Ürün Adı" FontSize="13" Foreground="#64748B" TextTrimming="CharacterEllipsis" MaxWidth="380"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <StackPanel Grid.Row="1" Margin="24" x:Name="PnlValorContainer">
                        <!-- Items will be generated here in code-behind -->
                    </StackPanel>
                    
                    <Border Grid.Row="2" Background="#FAFAFA" Padding="20,16" CornerRadius="0,0,16,16" BorderThickness="0,1,0,0" BorderBrush="#E2E8F0">
                        <Button Content="Kapat" HorizontalAlignment="Right" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#64748B" FontWeight="SemiBold" Click="BtnCloseValorDialog_Click"/>
                    </Border>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
