<UserControl x:Class="ArcelikExcelApp.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F4F7FE"
             Loaded="UserControl_Loaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Başlık Alanı -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Genel İstatistikler" FontSize="26" FontWeight="Bold" Foreground="#2B3674"/>
                <TextBlock Text="Sistemdeki ürünlerin, fiyatların ve kampanyaların güncel özeti" FontSize="14" Foreground="#A3AED0" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Üst İstatistik Kartları (Sayısal Veriler) -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="-8,0,-8,20">
                <!-- Toplam Ürün -->
                <materialDesign:Card Margin="8" UniformCornerRadius="16" Background="White">
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="56" Height="56" CornerRadius="28" Background="#F4F7FE">
                            <materialDesign:PackIcon Kind="PackageVariantClosed" Width="28" Height="28" Foreground="#4318FF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Toplam Ürün" FontSize="14" FontWeight="Medium" Foreground="#A3AED0"/>
                            <TextBlock x:Name="TxtTotalProducts" Text="0" FontSize="24" FontWeight="Bold" Foreground="#2B3674" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>

                <!-- KEA Ürün Sayısı -->
                <materialDesign:Card Margin="8" UniformCornerRadius="16" Background="White">
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="56" Height="56" CornerRadius="28" Background="#FEF2F2">
                            <materialDesign:PackIcon Kind="CoffeeMaker" Width="28" Height="28" Foreground="#E02020" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="KEA Ürünleri" FontSize="14" FontWeight="Medium" Foreground="#A3AED0"/>
                            <TextBlock x:Name="TxtKeaCount" Text="0" FontSize="24" FontWeight="Bold" Foreground="#2B3674" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>

                <!-- Beyaz Eşya Sayısı -->
                <materialDesign:Card Margin="8" UniformCornerRadius="16" Background="White">
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="56" Height="56" CornerRadius="28" Background="#EFF6FF">
                            <materialDesign:PackIcon Kind="WashingMachine" Width="28" Height="28" Foreground="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Beyaz Eşya" FontSize="14" FontWeight="Medium" Foreground="#A3AED0"/>
                            <TextBlock x:Name="TxtWgCount" Text="0" FontSize="24" FontWeight="Bold" Foreground="#2B3674" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>

                <!-- Yüklenen Dosyalar -->
                <materialDesign:Card Margin="8" UniformCornerRadius="16" Background="White">
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="56" Height="56" CornerRadius="28" Background="#FFFBEB">
                            <materialDesign:PackIcon Kind="FileExcel" Width="28" Height="28" Foreground="#D97706" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Yüklenen Excel" FontSize="14" FontWeight="Medium" Foreground="#A3AED0"/>
                            <TextBlock x:Name="TxtTotalFiles" Text="0" FontSize="24" FontWeight="Bold" Foreground="#2B3674" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>
            </UniformGrid>

            <!-- Orta Bölüm (Finansal Veriler & Kampanyalar) -->
            <Grid Grid.Row="2" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Sol Kısım: Finansal Ortalamalar Kartı (Gradyan Arka Planlı Şık Kart) -->
                <Border Grid.Column="0" CornerRadius="20" Margin="0,0,12,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#E02020" Offset="0.0" />
                            <GradientStop Color="#B91C1C" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,20">
                            <materialDesign:PackIcon Kind="Finance" Width="24" Height="24" Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock Text="Ortalama Fiyat Analizleri (60 Günlük Toptan)" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="KEA Ortalama Fiyat" FontSize="14" Foreground="#FECACA"/>
                                <TextBlock x:Name="TxtKeaAvgPrice" Text="0 ₺" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                            </StackPanel>

                            <Rectangle Grid.Column="1" Width="1" Fill="#FCA5A5" Margin="24,0" Opacity="0.5"/>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Beyaz Eşya Ortalama Fiyat" FontSize="14" Foreground="#FECACA"/>
                                <TextBlock x:Name="TxtWgAvgPrice" Text="0 ₺" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Sağ Kısım: Kampanya İstatistiği -->
                <materialDesign:Card Grid.Column="1" Margin="12,0,0,0" UniformCornerRadius="20" Background="White">
                    <Grid Margin="24">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Width="40" Height="40" CornerRadius="10" Background="#F0FDF4">
                                    <materialDesign:PackIcon Kind="TicketPercent" Width="24" Height="24" Foreground="#16A34A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Oliz Kampanyaları" FontSize="16" FontWeight="SemiBold" Foreground="#2B3674" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Toplam Aktif Kampanya" FontSize="13" Foreground="#A3AED0"/>
                            <TextBlock x:Name="TxtTotalCampaigns" Text="0" FontSize="28" FontWeight="Bold" Foreground="#2B3674" Margin="0,4,0,16"/>
                            
                            <TextBlock Text="Maliyetlerde Kampanya Kullanım Oranı" FontSize="12" FontWeight="Medium" Foreground="#A3AED0" Margin="0,0,0,8"/>
                            <Grid>
                                <ProgressBar x:Name="ProgCampaign" Value="0" Height="10" Foreground="#16A34A" Background="#E2E8F0" materialDesign:TransitionAssist.DisableTransitions="True"/>
                                <TextBlock x:Name="TxtCampaignRatio" Text="%0" FontSize="10" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>
            </Grid>

            <!-- Alt Bölüm: Tablo ve Veri Dağılımı -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Maliyet Hesaplamaları Kartı -->
                <materialDesign:Card Grid.Column="0" Margin="0,0,12,0" UniformCornerRadius="20" Background="White">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Grid Grid.Row="0" Margin="24,24,24,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Son Yapılan Maliyet Hesaplamaları" FontSize="18" FontWeight="Bold" Foreground="#2B3674" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="#F4F7FE" CornerRadius="12" Padding="12,4">
                                <TextBlock x:Name="TxtTotalCalculations" Text="Toplam: 0" FontSize="13" FontWeight="SemiBold" Foreground="#4318FF"/>
                            </Border>
                        </Grid>

                        <DataGrid x:Name="GridRecentCalculations" Grid.Row="1" Margin="24,0,24,24"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0"
                                  HeadersVisibility="Column" RowBackground="White"
                                  AlternatingRowBackground="#FAFAFA" GridLinesVisibility="None"
                                  materialDesign:DataGridAssist.CellPadding="12,8"
                                  MaxHeight="300" ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Kat." Binding="{Binding SourceTable}" Width="80"/>
                                <DataGridTextColumn Header="Kod" Binding="{Binding ProductCode}" Width="100"/>
                                <DataGridTextColumn Header="Baz Fiyat" Binding="{Binding PricePP, StringFormat={}{0:N2} ₺}" Width="90"/>
                                <DataGridTextColumn Header="İndirim" Binding="{Binding PriceConversion, StringFormat={}{0:N2} ₺}" Width="90"/>
                                <DataGridTextColumn Header="Net" Binding="{Binding PurchasePrice, StringFormat={}{0:N2} ₺}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </materialDesign:Card>

                <!-- Veritabanı Dağılımı -->
                <materialDesign:Card Grid.Column="1" Margin="12,0,0,0" UniformCornerRadius="20" Background="White">
                    <Grid Margin="24">
                        <StackPanel>
                            <TextBlock Text="Kategori Dağılımı" FontSize="18" FontWeight="Bold" Foreground="#2B3674" Margin="0,0,0,24"/>
                            
                            <!-- KEA -->
                            <StackPanel Margin="0,0,0,20">
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Küçük Ev Aletleri" FontSize="14" FontWeight="SemiBold" Foreground="#2B3674" HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="TxtKeaRatio" Text="%0" FontSize="14" FontWeight="Bold" Foreground="#E02020" HorizontalAlignment="Right"/>
                                </Grid>
                                <ProgressBar x:Name="ProgKea" Value="0" Height="8" Foreground="#E02020" Background="#FEF2F2" materialDesign:TransitionAssist.DisableTransitions="True"/>
                            </StackPanel>

                            <!-- Beyaz Eşya -->
                            <StackPanel Margin="0,0,0,20">
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Beyaz Eşya" FontSize="14" FontWeight="SemiBold" Foreground="#2B3674" HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="TxtWgRatio" Text="%0" FontSize="14" FontWeight="Bold" Foreground="#3B82F6" HorizontalAlignment="Right"/>
                                </Grid>
                                <ProgressBar x:Name="ProgWg" Value="0" Height="8" Foreground="#3B82F6" Background="#EFF6FF" materialDesign:TransitionAssist.DisableTransitions="True"/>
                            </StackPanel>

                            <!-- Bilgi Kutusu -->
                            <Border Background="#F4F7FE" CornerRadius="16" Padding="16" Margin="0,16,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Information" Width="24" Height="24" Foreground="#4318FF" VerticalAlignment="Center"/>
                                    <TextBlock Text="Ürün sayıları kayıtlı benzersiz ürün kodlarına göre hesaplanır." 
                                               FontSize="12" Foreground="#A3AED0" TextWrapping="Wrap" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
